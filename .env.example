VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# data.go.kr 공공데이터포털 API 키 (여객선 + 관광공사 OpenAPI 공용)
# https://www.data.go.kr 에서 아래 API 신청 후 발급
#   - 해양경찰청_여객선 항로정보 서비스 v4 (B554035)
#   - 한국관광공사_관광지집중률방문자추이예측정보 (B551011/TatsCnctrRateService)
#   - 한국관광공사_국문관광정보서비스 (B551011/KorService2)
#   - 한국관광공사_지역별관광수요강도 (B551011/TatsDmndItnsService)
#   - 한국관광공사_관광지별연관관광지정보 (B551011/TatsAtsRlatService)
#   - 한국관광공사_기초지자체중심관광지정보 (B551011/TourBasedList)
#   - 한국관광공사_두루누비정보서비스 (B551011/Durunubi)
#   - 한국관광공사_관광빅데이터정보서비스 (B551011/TatsBigdataService)
#   - 한국관광공사_생태관광정보 (B551011/GreenTourService1)
#   - 한국관광공사_무장애여행정보 (B551011/KorWithService1)
#   - 한국관광공사_반려동물_동반여행_데이터 (B551011/PetTourService1)
VITE_FERRY_API_KEY=your-data-go-kr-api-key

# Google/Kakao OAuth 키는 .env에 넣지 않습니다.
